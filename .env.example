# share-it host-port binding
#
# Copy this file to `.env` (which is gitignored) and edit as needed:
#   cp .env.example .env
#
# Docker Compose auto-loads `.env` and substitutes these into docker-compose.yml.
# After changing values, run `make restart` (or `docker compose up -d`).

# Interface the container's port is bound to on the host.
#   127.0.0.1   loopback only — safe default, requires a reverse proxy
#               (e.g. `tailscale serve`, nginx) to reach it from elsewhere.
#   0.0.0.0     all interfaces — exposes the service on every IP the host has.
#               Only do this on a trusted network (the app has no auth).
#   100.x.y.z   a specific Tailscale IP — reachable only over your tailnet.
#   192.168.x.y a specific LAN IP — reachable only on your local network.
BIND_ADDR=127.0.0.1

# Host port mapped to the container's port 3050.
HOST_PORT=3050
